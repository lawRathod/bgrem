{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "redirects": [
    {
      "source": "/",
      "destination": "/bgrem/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/bgrem/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ]
}
