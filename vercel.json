{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "rewrites": [
    {
      "source": "/bgrem",
      "destination": "/bgrem/"
    },
    {
      "source": "/bgrem/:path*",
      "destination": "/bgrem/:path*"
    }
  ],
  "headers": [
    {
      "source": "/bgrem/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ]
}
